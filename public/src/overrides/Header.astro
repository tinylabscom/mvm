---
// Override Starlight's Header component.
// On the splash page, render a clean landing-page header with hamburger menu.
// On all other pages, render the default Starlight Header.
import Default from "@astrojs/starlight/components/Header.astro";

const route = Astro.locals.starlightRoute;
const isSplash = route?.entry?.data?.template === "splash";

const base = import.meta.env.BASE_URL;
const b = base.endsWith("/") ? base : `${base}/`;
const navLinks = [
  { label: "Docs", href: `${b}getting-started/installation/` },
  { label: "Quick Start", href: `${b}getting-started/quickstart/` },
  { label: "Guides", href: `${b}guides/nix-flakes/` },
  { label: "Reference", href: `${b}reference/cli-commands/` },
];
---

{isSplash ? (
  <header class="landing-header">
    <div class="landing-header-inner">
      <a href={b} class="landing-logo">
        <span class="landing-logo-text">mvm</span>
      </a>
      <nav class="landing-nav">
        {navLinks.map(link => (
          <a href={link.href} class="landing-nav-link">{link.label}</a>
        ))}
      </nav>
      <div class="landing-nav-right">
        <a href="https://github.com/auser/mvm" target="_blank" rel="noopener" class="landing-github-link" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"/>
          </svg>
        </a>
        <button class="landing-hamburger" aria-label="Toggle navigation" aria-expanded="false">
          <svg class="hamburger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg class="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>
    <nav class="landing-mobile-nav" aria-label="Mobile navigation">
      {navLinks.map(link => (
        <a href={link.href} class="landing-mobile-link">{link.label}</a>
      ))}
      <a href="https://github.com/auser/mvm" target="_blank" rel="noopener" class="landing-mobile-link">
        GitHub
      </a>
    </nav>
  </header>
) : (
  <Default />
)}

<script>
  const btn = document.querySelector('.landing-hamburger');
  const menu = document.querySelector('.landing-mobile-nav');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('is-open');
      btn.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', String(open));
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('is-open');
        btn.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

<style>
  .landing-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    backdrop-filter: blur(12px);
  }

  .landing-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .landing-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .landing-logo-text {
    font-family: "JetBrains Mono", "SF Mono", "Cascadia Code", "Fira Code", Consolas, monospace;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Desktop nav */
  .landing-nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 50em) {
    .landing-nav {
      display: flex;
    }
  }

  .landing-nav-link {
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .landing-nav-link:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-bg-inline-code);
  }

  .landing-nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .landing-github-link {
    display: flex;
    align-items: center;
    color: var(--sl-color-gray-2);
    transition: color 0.15s;
  }

  .landing-github-link:hover {
    color: var(--sl-color-text);
  }

  /* Hamburger button — visible on mobile only */
  .landing-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .landing-hamburger:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-bg-inline-code);
  }

  .landing-hamburger .close-icon {
    display: none;
  }

  .landing-hamburger.is-open .hamburger-icon {
    display: none;
  }

  .landing-hamburger.is-open .close-icon {
    display: block;
  }

  @media (min-width: 50em) {
    .landing-hamburger {
      display: none;
    }
  }

  /* Mobile nav panel */
  .landing-mobile-nav {
    display: none;
    flex-direction: column;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem 1rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }

  .landing-mobile-nav.is-open {
    display: flex;
  }

  @media (min-width: 50em) {
    .landing-mobile-nav {
      display: none !important;
    }
  }

  .landing-mobile-link {
    display: block;
    padding: 0.75rem 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-bottom: 1px solid var(--sl-color-hairline-light);
    transition: color 0.15s;
  }

  .landing-mobile-link:last-child {
    border-bottom: none;
  }

  .landing-mobile-link:hover {
    color: var(--sl-color-text);
  }
</style>
