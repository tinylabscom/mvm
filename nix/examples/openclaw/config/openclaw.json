{
  "gateway": {
    "mode": "local",
    "channelHealthCheckMinutes": 0,
    "auth": { "mode": "none" },
    "reload": { "mode": "off" },
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "groups": {
        "*": { "requireMention": true }
      },
      "sendReadReceipts": true,
      "ackReaction": {
        "emoji": "👀",
        "direct": true,
        "group": "mentions"
      },
      "textChunkLimit": 4000,
      "mediaMaxMb": 50
    }
  }
}
