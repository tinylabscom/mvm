# OpenClaw API Keys and Secrets
# Mount this directory with: --secrets-dir ./secrets
# Sourced at runtime from /mnt/secrets/api-keys.env

# Anthropic API key (required for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional, for OpenAI models)
# OPENAI_API_KEY=sk-...

# Gateway authentication token (overrides default "mvm")
# OPENCLAW_GATEWAY_TOKEN=my-secret-token
