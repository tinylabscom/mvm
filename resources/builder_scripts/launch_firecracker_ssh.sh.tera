set -euo pipefail
mkdir -p {{run_dir}}
rm -f {{socket}}
firecracker \
    --api-sock {{socket}} \
    --config-file {{config}} \
    --log-path {{log}} \
    --level Info \
    &
FC_PID=$!
echo "$FC_PID" > {{pid}}
sleep 1
if ! kill -0 "$FC_PID" 2>/dev/null; then
    echo "firecracker failed to start (ssh mode)" >&2
    cat {{log}} >&2 || true
    exit 1
fi
